pipeline {
    agent any

    stages {
        stage('Switch Traffic to Stable (Green)') {
            steps {
                sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@172.31.34.177 "kubectl patch service sentiment-api-service -p '{\"spec\":{\"selector\":{\"app\":\"sentiment-api\",\"slot\":\"green\"}}}'"
                '''
            }
        }
    }
}
