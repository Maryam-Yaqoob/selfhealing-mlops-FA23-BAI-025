pipeline {
    agent any

    stages {
        stage('Switch Traffic to Stable (Green)') {
            steps {
                sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@172.31.34.177 "cat > /tmp/rollback-patch.json <<'PATCH'
{\"spec\":{\"selector\":{\"app\":\"sentiment-api\",\"slot\":\"green\"}}}
PATCH
kubectl patch service sentiment-api-service --patch-file /tmp/rollback-patch.json"
                '''
            }
        }
    }
}
