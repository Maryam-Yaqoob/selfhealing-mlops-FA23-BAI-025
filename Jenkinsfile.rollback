pipeline {
    agent any
    triggers {
        GenericTrigger(
            token: 'ROLLBACK_E31CBC_TOKEN'
        )
    }
    stages {
        stage('Switch Traffic to Stable (Green)') {
            steps {
                sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@172.31.34.177 \
                    "kubectl patch service sentiment-api-service -p '{\"spec\":{\"selector\":{\"slot\":\"green\"}}}'"
                '''
            }
        }
    }
}
