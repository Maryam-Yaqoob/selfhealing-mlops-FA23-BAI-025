pipeline {
    agent any
    options {
        // Yeh hidden default automatic checkout ko crash hone se rokega
        skipDefaultCheckout()
    }
    environment {
        DOCKERHUB_USER = 'maryamyaqoob8381'
        IMAGE_NAME     = 'sentiment-api'
    }
    stages {
        stage('Fetch Rollback Script') {
            steps {
                // Ab sirf hamara yeh explicit safe checkout chalega
                checkout scm: [
                    $class: 'GitSCM', 
                    branches: [[name: '*/main']], 
                    extensions: [], 
                    userRemoteConfigs: [[url: 'https://github.com/Maryam-Yaqoob/selfhealing-mlops-FA23-BAI-025.git']]
                ]
            }
        }
        stage('Rollback Deployment') {
            steps {
                echo "Alertmanager triggered fallback loop! Reverting cluster to stable dynamic tag..."
                sh "kubectl apply -f k8s/pvc.yaml --kubeconfig=/tmp/.kube/config"
                
                sh "kubectl set image deployment/sentiment-blue-deployment sentiment-api=${DOCKERHUB_USER}/${IMAGE_NAME}:stable --kubeconfig=/tmp/.kube/config"
                sh "kubectl set image deployment/sentiment-green-deployment sentiment-api=${DOCKERHUB_USER}/${IMAGE_NAME}:stable --kubeconfig=/tmp/.kube/config"
                
                sh "kubectl apply -f k8s/service.yaml --kubeconfig=/tmp/.kube/config"
                echo "Cluster state successfully self-healed and rolled back to stable release!"
            }
        }
    }
}
